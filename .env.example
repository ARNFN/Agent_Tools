# Anthropic-compatible API (required for llm.py demo client)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# QWeather JWT auth (optional, for get_weather / get_region)
QWEATHER_HOST=
QWEATHER_KID=
QWEATHER_PROJECT_ID=
QWEATHER_PRIVATE_KEY_PATH=./qweather_key/ed25519-private.pem
QWEATHER_GEO_RANGE=

VAULT_KEY=

# Tavily web search (optional) https://tavily.com
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT=20
TAVILY_API_KEY=

# Assistant output: enable=Rich Markdown, otherwise plain text
ENABLE_RICH=enable

# File tools: external paths allowed outside repo root (one per line, uncomment to use)
# AccessablePath=/path/to/external/project

# File read limits (optional, defaults: 524288 bytes / 1000 lines)
# FILE_READ_MAX_RETURN_BYTES=524288
# FILE_READ_MAX_LINES=1000

# Database (optional, for db_connect / db_execute_sql)
DB_TYPE=mysql
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=
